{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx api/\\[...path\\].ts",
    "build": "vite build && esbuild api/\\[...path\\].ts --bundle --platform=node --outfile=dist/server.cjs --format=cjs --packages=external",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.4",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "5.4.296",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-legacy": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "terser": "^5.46.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.0.0"
  }
}
